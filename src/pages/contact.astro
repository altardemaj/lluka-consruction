---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact"
  description="Contact LLUKA Construction for a free estimate in Westchester County and Connecticut."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Contact LLUKA Construction</span>
      <h1>Request Your Free Estimate</h1>
      <p>
        Tell us about your project goals, timeline, and scope. We provide responsive communication and clear
        next steps from the first call.
      </p>
    </div>
  </section>

  <div class="page-shell">
  <section class="page-section page-section-light">
    <div class="container">
      <div class="section-intro">
        <span class="eyebrow">Get in Touch</span>
        <h2>Connect With Our Team</h2>
      </div>
      <div class="grid grid-3">
        <article class="card">
          <h2>Call</h2>
          <p><a href="tel:+19147559606">(914) 755-9606</a></p>
        </article>
        <article class="card">
          <h2>Email</h2>
          <p><a href="mailto:info@llukaconstruction.com">info@llukaconstruction.com</a></p>
        </article>
        <article class="card">
          <h2>Service Region</h2>
          <p>Westchester County, NY and Connecticut</p>
        </article>
      </div>
      <div class="nav-ctas" style="margin-top: 1rem;">
        <a class="btn btn-primary" href="mailto:info@llukaconstruction.com">Get a Free Estimate</a>
        <a class="btn btn-outline" href="tel:+19147559606">Call Now</a>
      </div>
    </div>
  </section>

  <section class="page-cta">
    <div class="container cta-box">
      <div>
        <span class="kicker">Let’s Talk</span>
        <h2>Ready to Discuss Your Next Construction Project?</h2>
        <p>Our team serves Westchester County and Connecticut with trusted, high-quality execution.</p>
      </div>
      <div class="nav-ctas">
        <a class="btn btn-primary" href="mailto:info@llukaconstruction.com">Get a Free Estimate</a>
        <a class="btn btn-ghost-light" href="tel:+19147559606">Call Now</a>
      </div>
    </div>
  </section>
  </div>
</MainLayout>
