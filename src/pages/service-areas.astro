---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Service Areas"
  description="LLUKA Construction proudly serves Westchester County and Connecticut."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Service Areas</span>
      <h1>Proudly Serving Westchester County and Connecticut</h1>
      <p>
        LLUKA Construction provides responsive, reliable service throughout the region with clear communication
        and professional project management.
      </p>
    </div>
  </section>

  <div class="page-shell">
  <section class="page-section page-section-light">
    <div class="container">
      <div class="section-intro">
        <span class="eyebrow">Coverage Region</span>
        <h2>Areas We Commonly Serve</h2>
      </div>
      <div class="grid grid-3">
        <article class="card">
          <h2>Westchester County, NY</h2>
          <p>Residential and light commercial construction services across local communities.</p>
        </article>
        <article class="card">
          <h2>Fairfield County, CT</h2>
          <p>Remodeling and improvement projects for homes and businesses throughout the county.</p>
        </article>
        <article class="card">
          <h2>Nearby Areas</h2>
          <p>Reach out to confirm availability for neighboring locations and project timelines.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="page-cta">
    <div class="container cta-box">
      <div>
        <span class="kicker">Confirm Availability</span>
        <h2>Planning a Project in the Area?</h2>
        <p>Call LLUKA Construction to confirm scheduling and get a detailed estimate for your location.</p>
      </div>
      <div class="nav-ctas">
        <a class="btn btn-primary" href="/contact">Get a Free Estimate</a>
        <a class="btn btn-ghost-light" href="tel:+19147559606">Call Now</a>
      </div>
    </div>
  </section>
  </div>
</MainLayout>
