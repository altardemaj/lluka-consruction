---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Services"
  description="Explore LLUKA Construction services including plumbing, remodeling, and general construction."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Our Services</span>
      <h1>Construction and Remodeling Services You Can Rely On</h1>
      <p>
        LLUKA Construction delivers premium, detail-focused services across Westchester County and
        Connecticut with reliable scheduling and strong project execution.
      </p>
    </div>
  </section>

  <div class="page-shell">
  <section class="page-section page-section-light">
    <div class="container">
      <div class="section-intro">
        <span class="eyebrow">Service Lines</span>
        <h2>Built Around Quality, Communication, and Lasting Value</h2>
      </div>
      <div class="grid grid-3">
        <article class="card">
          <h2>Plumbing Services</h2>
          <p>Full-service plumbing solutions for renovations, repairs, and system upgrades.</p>
          <a href="/services/plumbing" class="btn btn-outline">View Plumbing</a>
        </article>
        <article class="card">
          <h2>General Construction</h2>
          <p>Structural updates, interior improvements, and end-to-end project coordination.</p>
          <a href="/services/general-construction" class="btn btn-outline">View General Construction</a>
        </article>
        <article class="card">
          <h2>Bathroom Remodeling</h2>
          <p>Modern, elegant bathrooms built with durable materials and practical design.</p>
          <a href="/services/bathroom-remodeling" class="btn btn-outline">View Bathroom Remodeling</a>
        </article>
        <article class="card">
          <h2>Kitchen Remodeling</h2>
          <p>Custom kitchen transformations with premium finishes and optimized workflow.</p>
          <a href="/services/kitchen-remodeling" class="btn btn-outline">View Kitchen Remodeling</a>
        </article>
      </div>
    </div>
  </section>

  <section class="page-cta">
    <div class="container cta-box">
      <div>
        <span class="kicker">Start With Confidence</span>
        <h2>Need a Trusted Team for Your Next Project?</h2>
        <p>Call now or request a free estimate for work in Westchester County and Connecticut.</p>
      </div>
      <div class="nav-ctas">
        <a class="btn btn-primary" href="/contact">Get a Free Estimate</a>
        <a class="btn btn-ghost-light" href="tel:+19147559606">Call Now</a>
      </div>
    </div>
  </section>
  </div>
</MainLayout>
