---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="About"
  description="Learn about LLUKA Construction, a licensed and insured contractor serving Westchester County and Connecticut."
>
  <div class="about-page">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">About LLUKA Construction</span>
      <h1>A Proven Contractor Built on Reputation, Reliability, and Results</h1>
      <p>
        LLUKA Construction serves Westchester County and Connecticut with premium workmanship, transparent
        communication, and disciplined project execution from start to finish.
      </p>
    </div>
  </section>

  <div class="page-shell">
  <section class="page-section page-section-light">
    <div class="container spotlight-grid">
      <figure class="spotlight-media">
        <img src="/images/projects/Johnny/johnny-owner.jpeg" alt="Johnny, owner of LLUKA Construction in Mahopac, New York" loading="lazy" />
      </figure>
      <article class="spotlight-content">
        <span class="eyebrow">Owner Spotlight</span>
        <h2>Meet Johnny, Owner of LLUKA Construction</h2>
        <p class="lead-copy">
          Johnny, owner of LLUKA Construction, brings over 18 years of hands-on experience delivering
          high-quality residential and commercial work. Based in Mahopac, New York, he leads every project
          with a clear standard: do what you say, do it right, and stand behind the result.
        </p>
        <p>
          Clients across Westchester County and Connecticut know Johnny as a man of his word. He is
          hands-on, detail-oriented, and deeply committed to hard work, strong communication, and quality
          craftsmanship from the first walkthrough to the final punch list.
        </p>
      </article>
    </div>
  </section>

  <section class="page-section page-section-dark">
    <div class="container">
      <span class="eyebrow">Why Clients Choose LLUKA Construction</span>
      <h2>Professional Standards You Can Feel at Every Stage of the Job</h2>
      <div class="why-grid">
        <article class="why-card">
          <h3>Honest, Straightforward Communication</h3>
          <p>
            You get clear updates, realistic expectations, and direct answers so you can make confident
            decisions throughout your project.
          </p>
        </article>
        <article class="why-card">
          <h3>Hands-On Leadership</h3>
          <p>
            Johnny stays involved and detail-focused, ensuring each phase is executed properly with strong
            coordination and accountability.
          </p>
        </article>
        <article class="why-card">
          <h3>Clean Sites, Strong Execution</h3>
          <p>
            LLUKA Construction and its professional team are committed to honest work, organized job sites,
            and clean, precise finishes.
          </p>
        </article>
        <article class="why-card">
          <h3>Results Clients Trust</h3>
          <p>
            Licensed and insured service, premium workmanship, and long-term reliability for homes and
            businesses across Westchester County and Connecticut.
          </p>
        </article>
      </div>
      <div class="lead-cta surface-card">
        <h3>Ready for Your Next Project?</h3>
        <p>
          Call LLUKA Construction today to discuss your scope and get a clear estimate from a trusted local
          team.
        </p>
        <div class="nav-ctas">
          <a class="btn btn-primary" href="tel:+19147559606">Call Now</a>
          <a class="btn btn-outline" href="/contact">Get a Free Estimate</a>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section page-section-light">
    <div class="container">
      <span class="eyebrow">About LLUKA Construction</span>
      <h2>A Professional Team Built on Trust and Craftsmanship</h2>
      <p>
        LLUKA Construction is a licensed and insured company focused on delivering dependable workmanship,
        transparent communication, and lasting value for every client.
      </p>
      <p>
        We work with homeowners and businesses throughout Westchester County and Connecticut, handling
        projects from selective upgrades to full-scale renovations.
      </p>
    </div>
  </section>

  <section class="page-cta">
    <div class="container cta-box">
      <div>
        <h2>Let’s Discuss Your Vision</h2>
        <p>We are ready to plan your next project and provide a clear, detailed estimate.</p>
      </div>
      <div class="nav-ctas">
        <a class="btn btn-primary" href="/contact">Get a Free Estimate</a>
        <a class="btn btn-ghost-light" href="tel:+19147559606">Call Now</a>
      </div>
    </div>
  </section>
  </div>
</MainLayout>
