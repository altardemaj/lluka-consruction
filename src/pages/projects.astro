---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Projects"
  description="See sample LLUKA Construction projects across Westchester County and Connecticut."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Featured Work</span>
      <h1>Project Portfolio</h1>
      <p>
        Explore recent LLUKA Construction projects featuring complete galleries from finished results to
        progress and detail work.
      </p>
    </div>
  </section>

  <div class="page-shell">
  <section class="page-section page-section-light">
    <div class="container">
      <div class="section-intro">
        <span class="eyebrow">Recent Projects</span>
        <h2>Built for Performance, Finish Quality, and Long-Term Value</h2>
      </div>

      <article class="project-card">
        <h2>Deck Remodel</h2>
        <p class="project-meta">Westchester County / Connecticut Region - Residential Exterior Upgrade</p>
        <p>
          This deck remodel highlights staged progress, precision finishing, and a durable final build
          designed for long-term outdoor use.
        </p>
        <div class="project-gallery">
          <figure class="gallery-item">
            <img src="/images/projects/deck-remodel-1/deck-progress.jpeg" alt="Deck remodel in progress stage one" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/deck-remodel-1/deck-progress-2.jpeg" alt="Deck remodel in progress stage two" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/deck-remodel-1/deck-finished.jpeg" alt="Finished deck remodel result view one" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/deck-remodel-1/deck-finished-1.jpeg" alt="Finished deck remodel result view two" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/deck-remodel-1/deck-finished-2.jpeg" alt="Finished deck remodel result view three" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
        </div>
      </article>

      <article class="project-card">
        <h2>Fireplace Stone Install</h2>
        <p class="project-meta">Custom Interior Stonework - Residential Feature Installation</p>
        <p>
          Custom stone fireplace installation featuring precision stonework, vertical accent design, and a
          clean finished centerpiece that adds warmth, texture, and luxury to the space.
        </p>
        <div class="project-gallery">
          <figure class="gallery-item">
            <img src="/images/projects/fireplace-stone-1/fireplace-finished-1.jpeg" alt="Finished custom stone fireplace result view one" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/fireplace-stone-1/fireplace-finished-2.jpeg" alt="Finished custom stone fireplace result view two" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/fireplace-stone-1/fireplace-progress-1.jpeg" alt="Stone fireplace installation in progress stage one" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/fireplace-stone-1/fireplace-progress-2.jpeg" alt="Stone fireplace installation in progress stage two" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/fireplace-stone-1/fireplace-progress-3.jpeg" alt="Stone fireplace installation in progress stage three" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/fireplace-stone-1/fireplace-detail-2.jpeg" alt="Stone fireplace detail close-up view one" loading="lazy" />
            <figcaption>Detail View</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/fireplace-stone-1/fireplace-detail-3.jpeg" alt="Stone fireplace detail close-up view two" loading="lazy" />
            <figcaption>Detail View</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/fireplace-stone-1/fireplace-detail-4.jpeg" alt="Stone fireplace detail close-up view three" loading="lazy" />
            <figcaption>Detail View</figcaption>
          </figure>
        </div>
      </article>

      <article class="project-card">
        <h2>Kitchen Remodel</h2>
        <p class="project-meta">Premium Interior Renovation - Custom Kitchen Upgrade</p>
        <p>
          Full kitchen remodel focused on improved functionality, modern finishes, and clean execution from
          demolition through final installation.
        </p>
        <div class="project-gallery">
          <figure class="gallery-item">
            <img src="/images/projects/kitchen-1/final-product.jpg" alt="Finished kitchen remodel final result" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/kitchen-1/final-product-1.jpg" alt="Finished kitchen remodel alternate final view" loading="lazy" />
            <figcaption>Detail Work</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/kitchen-1/step-1.jpg" alt="Kitchen remodel first stage in progress" loading="lazy" />
            <figcaption>Before</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/kitchen-1/step-2.jpg" alt="Kitchen remodel second stage in progress" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
        </div>
      </article>

      <article class="project-card">
        <h2>Pool Deck</h2>
        <p class="project-meta">Exterior Hardscape Build - Precision Deck Installation</p>
        <p>
          Outdoor pool deck project completed with durable materials, structured layout planning, and a
          polished final finish built for long-term performance.
        </p>
        <div class="project-gallery">
          <figure class="gallery-item">
            <img src="/images/projects/pool-deck/final-product.jpg" alt="Finished pool deck final result view one" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/pool-deck/final-product-1.jpg" alt="Finished pool deck final result view two" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/pool-deck/progress-1.jpg" alt="Pool deck installation before and early progress stage" loading="lazy" />
            <figcaption>Before</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/pool-deck/progress-2.jpg" alt="Pool deck installation in progress stage two" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/pool-deck/progress-3.jpg" alt="Pool deck installation in progress stage three" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/pool-deck/progress-4.jpg" alt="Pool deck detail workmanship during progress stage" loading="lazy" />
            <figcaption>Detail Work</figcaption>
          </figure>
        </div>
      </article>

      <article class="project-card">
        <h2>Home Remodel</h2>
        <p class="project-meta">Residential Interior Transformation - Multi-Stage Remodel</p>
        <p>
          Home remodeling project showcasing methodical progress, quality construction standards, and a
          clean finished result designed to elevate comfort and long-term value.
        </p>
        <div class="project-gallery">
          <figure class="gallery-item">
            <img src="/images/projects/remodel-2/finished-product.jpg" alt="Finished home remodel final result" loading="lazy" />
            <figcaption>Finished Result</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/remodel-2/progress-1.jpg" alt="Home remodel before and early progress stage" loading="lazy" />
            <figcaption>Before</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/remodel-2/progress-2.jpg" alt="Home remodel in progress stage two" loading="lazy" />
            <figcaption>In Progress</figcaption>
          </figure>
          <figure class="gallery-item">
            <img src="/images/projects/remodel-2/progress-3.jpg" alt="Home remodel detail work during construction" loading="lazy" />
            <figcaption>Detail Work</figcaption>
          </figure>
        </div>
      </article>
    </div>
  </section>

  <section class="page-cta">
    <div class="container cta-box">
      <div>
        <span class="kicker">Your Project Next</span>
        <h2>Want Results Like These on Your Property?</h2>
        <p>Call LLUKA Construction to discuss scope, budget, and timeline with a trusted local team.</p>
      </div>
      <div class="nav-ctas">
        <a class="btn btn-primary" href="/contact">Get a Free Estimate</a>
        <a class="btn btn-ghost-light" href="tel:+19147559606">Call Now</a>
      </div>
    </div>
  </section>
  </div>
</MainLayout>
