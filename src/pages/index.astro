---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="LLUKA Construction"
  description="Premium remodeling and construction services in Westchester County & Connecticut"
  ogTitle="LLUKA Construction"
  ogDescription="Premium remodeling and construction services in Westchester County & Connecticut"
  ogImage="/images/projects/deck-remodel-1/deck-finished.jpeg"
  ogType="website"
  twitterCard="summary_large_image"
>
  <div class="home-dark">
  <section class="hero hero-background">
    <div class="container hero-grid">
      <div>
        <h1 class="hero-brand-title">LLUKA Construction</h1>
        <h2 class="hero-subheadline">Premium Remodeling &amp; Construction You Can Trust</h2>
        <p class="hero-support-line">
          Serving Westchester County &amp; Connecticut with precision, reliability, and craftsmanship built
          to last
        </p>
        <div class="nav-ctas">
          <a class="btn btn-primary" href="/contact">Get a Free Estimate</a>
          <a class="btn btn-outline" href="tel:+19147559606">Call Now</a>
        </div>
        <div class="trust-badges">
          <span class="badge">Licensed &amp; Insured</span>
          <span class="badge">Locally Trusted Team</span>
          <span class="badge">Quality Workmanship</span>
          <span class="badge">Transparent Timelines</span>
        </div>
      </div>
      <aside class="hero-panel">
        <h2>Built for Confidence</h2>
        <ul>
          <li>Dedicated oversight from planning through completion</li>
          <li>Professional crews and clean, organized worksites</li>
          <li>Premium materials matched to your project goals</li>
          <li>Consistent updates from quote to final walkthrough</li>
        </ul>
        <div class="hero-meta">
          <div class="stat">
            <strong>Westchester County</strong>
            <span>Primary NY service area</span>
          </div>
          <div class="stat">
            <strong>Connecticut</strong>
            <span>Serving nearby communities</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <span class="eyebrow">What We Do</span>
      <h2>Our Core Services</h2>
      <div class="grid grid-3">
        <article class="card service-card">
          <div class="service-icon">PL</div>
          <h3>Plumbing</h3>
          <p>
            Installations, repairs, and strategic system upgrades for kitchens, bathrooms, and full-home
            remodels.
          </p>
          <a href="/services/plumbing" class="service-link">Learn More</a>
        </article>
        <article class="card service-card">
          <div class="service-icon">GC</div>
          <h3>General Construction</h3>
          <p>
            Framing, interior and exterior improvements, and reliable project coordination from start to
            finish.
          </p>
          <a href="/services/general-construction" class="service-link">Learn More</a>
        </article>
        <article class="card service-card">
          <div class="service-icon">RM</div>
          <h3>Bathroom &amp; Kitchen Remodeling</h3>
          <p>
            Tailored remodeling solutions that combine premium finishes, practical layouts, and long-term
            durability.
          </p>
          <a href="/services" class="service-link">Explore Services</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-white owner-spotlight">
    <div class="container spotlight-grid spotlight-grid-premium">
      <figure class="spotlight-media spotlight-media-premium">
        <img src="/images/projects/Johnny/johnny-owner.jpeg" alt="Johnny, owner of LLUKA Construction" loading="lazy" />
      </figure>
      <article class="spotlight-content spotlight-content-premium">
        <span class="eyebrow">Owner Spotlight</span>
        <h2>Meet Johnny, Owner of LLUKA Construction</h2>
        <p class="lead-copy">
          Johnny has over 18 years of hands-on construction experience across residential and commercial
          projects. Based in Mahopac, New York, he has built LLUKA Construction on hard work, honest
          communication, and quality craftsmanship clients can trust across Westchester County and
          Connecticut.
        </p>
        <ul class="value-list">
          <li>Man of his word with a reputation built over many years</li>
          <li>Hands-on leadership and detail-oriented project execution</li>
          <li>Clean job sites, reliable timelines, and strong results</li>
        </ul>
        <div class="nav-ctas">
          <a class="btn btn-primary" href="tel:+19147559606">Call Now</a>
          <a class="btn btn-outline" href="/about">Learn More About Johnny</a>
        </div>
      </article>
    </div>
  </section>

  <section class="section section-dark owner-cta-band">
    <div class="container owner-cta-wrap">
      <div>
        <span class="kicker">Trusted Local Contractor</span>
        <h2>Talk Directly With Johnny About Your Next Project</h2>
        <p>
          If you want honest guidance, strong execution, and results you can feel confident about, call
          LLUKA Construction today.
        </p>
      </div>
      <div class="nav-ctas">
        <a class="btn btn-ghost-light" href="tel:+19147559606">Call Now</a>
        <a class="btn btn-primary" href="/contact">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <section class="section section-white project-feature">
    <div class="container">
      <span class="eyebrow">Featured Project</span>
      <h2>Deck Remodel in Progress to Finished Result</h2>
      <p>
        A recent deck remodel showcasing structural progress, finish carpentry, and a final clean,
        high-quality outdoor space.
      </p>
      <div class="project-gallery">
        <figure class="gallery-item wide">
          <img src="/images/projects/deck-remodel-1/deck-progress.jpeg" alt="Deck remodel in progress view" loading="lazy" />
          <figcaption>In Progress</figcaption>
        </figure>
        <figure class="gallery-item">
          <img src="/images/projects/deck-remodel-1/deck-finished.jpeg" alt="Finished deck remodel result angle one" loading="lazy" />
          <figcaption>Finished Result</figcaption>
        </figure>
        <figure class="gallery-item">
          <img src="/images/projects/deck-remodel-1/deck-finished-1.jpeg" alt="Finished deck remodel result angle two" loading="lazy" />
          <figcaption>Finished Result</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <span class="eyebrow">Featured Project</span>
      <h2>Fireplace Stone Install</h2>
      <p>
        Custom stone fireplace installation featuring precision stonework, vertical accent design, and a
        clean finished centerpiece that adds warmth, texture, and luxury to the space.
      </p>
      <div class="project-gallery">
        <figure class="gallery-item wide">
          <img src="/images/projects/fireplace-stone-1/fireplace-finished-1.jpeg" alt="Finished custom stone fireplace centerpiece" loading="lazy" />
          <figcaption>Finished Result</figcaption>
        </figure>
        <figure class="gallery-item">
          <img src="/images/projects/fireplace-stone-1/fireplace-progress-3.jpeg" alt="Fireplace stone installation in progress" loading="lazy" />
          <figcaption>In Progress</figcaption>
        </figure>
        <figure class="gallery-item">
          <img src="/images/projects/fireplace-stone-1/fireplace-detail-3.jpeg" alt="Detail close-up of custom stone fireplace finish" loading="lazy" />
          <figcaption>Detail View</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section-white testimonial-section">
    <div class="container">
      <span class="eyebrow">Client Feedback</span>
      <h2>What Clients Appreciate About Working With LLUKA</h2>
      <div class="grid grid-3">
        <article class="testimonial-card">
          <div class="quote-mark">"</div>
          <p>
            The crew was professional from day one. The scope, schedule, and communication were clear the
            entire time.
          </p>
          <div class="author">Homeowner, Westchester County</div>
        </article>
        <article class="testimonial-card">
          <div class="quote-mark">"</div>
          <p>
            Our kitchen remodel turned out exactly as planned. The team kept the site clean and stayed on
            timeline.
          </p>
          <div class="author">Residential Client, Connecticut</div>
        </article>
        <article class="testimonial-card">
          <div class="quote-mark">"</div>
          <p>
            Reliable, transparent, and detail-focused. We felt confident at every milestone of the project.
          </p>
          <div class="author">Property Owner, Regional Service Area</div>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-band section-dark">
    <div class="container cta-box">
      <div>
        <span class="kicker">Start Your Project</span>
        <h2>Ready to Build With a Team You Can Trust?</h2>
        <p>Request a clear, no-obligation estimate for projects in Westchester County and Connecticut.</p>
      </div>
      <div class="nav-ctas">
        <a class="btn btn-primary" href="/contact">Get a Free Estimate</a>
        <a class="btn btn-ghost-light" href="tel:+19147559606">Call Now</a>
      </div>
    </div>
  </section>
  </div>
</MainLayout>
